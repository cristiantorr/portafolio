<section
  id="experiencia"
  data-section="experiencia"
  class="section scroll-m-20 w-full mx-auto container lg:max-w-4xl md:max-w-2xl"
>
  <h2
    class="flex items-center mb-6 text-3xl font-semibold gap-x-3 text-black/80 dark:text-white"
  >
    <svg
