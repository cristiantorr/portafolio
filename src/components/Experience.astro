      <path d="M12 12l0 .01"></path>
      <path d="M3 13a20 20 0 0 0 18 0"></path>
    </svg>
    Experiencia laboral
  </h2>
  <ol class="relative mt-16">
    {
      EXPERIENCE.map((experience) => (
