              <div class="sticky top-0">
                <span class="text-yellow-400 -left-[42px] absolute rounded-full text-5xl">
                  &bull;
                </span>

                <h3 class="text-xl font-bold text-yellow-400">
                  {experience.title}
                </h3>
                <h4 class="font-semibold text-xl text-gray-600 dark:text-white">
                  {experience.company}
                </h4>
                <time class="p-0 m-0 text-sm text-gray-600/80 dark:text-white/80">
                  {experience.date}
                </time>
              </div>
            </div>
            <div class="relative flex flex-col gap-2 pb-4 text-gray-600 dark:text-gray-300 md:col-span-3">
              <p set:html={experience.description} />
              {experience.link && (
                <a
                  href={experience.link}
                  role="link"
                  class="inline-flex items-center text-lg font-medium text-yellow-500 dark:text-yellow-200 dark:hover:text-yellow-300 hover:text-yellow-700"
                  target="_blank"
                  rel="noopener noreferrer"
